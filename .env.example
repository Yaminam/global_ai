# Environment Variables Template

# Copy this file to .env and fill in the actual values

# ======================
# Flask Configuration
# ======================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ======================
# Storage Configuration
# ======================
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=1024
UPLOAD_FOLDER=./storage/datasets
PROCESSED_FOLDER=./storage/processed
RESULTS_FOLDER=./storage/results

# ======================
# Processing Configuration
# ======================
MAX_WORKERS=4
JOB_TIMEOUT_MINUTES=60
MAX_BATCH_SIZE=10000
ENABLE_STREAMING=True
ENABLE_ASYNC=True

# ======================
# Analytics Configuration
# ======================
ENABLE_ANOMALY_DETECTION=True
ENABLE_TREND_ANALYSIS=True
ENABLE_FORECASTING=True
ANOMALY_METHOD=isolation_forest
ANOMALY_CONTAMINATION=0.05

# ======================
# Security Configuration
# ======================
ENABLE_CORS=True
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1
REQUIRE_API_KEY=False
SESSION_COOKIE_SECURE=False

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_SIZE_MB=100

# ======================
# Cache Configuration
# ======================
CACHE_ENABLED=True
CACHE_TYPE=memory
CACHE_TTL_HOURS=24
CACHE_MAX_ENTRIES=1000

# ======================
# Database Configuration (Optional)
# ======================
DATABASE_TYPE=json
DATABASE_URL=sqlite:///sadul_globalai.db
DATABASE_ECHO=False

# ======================
# External Services (Optional)
# ======================
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Sendgrid (for email notifications)
SENDGRID_API_KEY=

# ======================
# Application Settings
# ======================
APP_NAME=Advanced Smart Data Processing & Analytics Platform
APP_VERSION=1.0.0
APP_DESCRIPTION=A comprehensive data processing and analytics platform
