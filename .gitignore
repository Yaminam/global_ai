# .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Flask
instance/
.webassets-cache

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml

# Database
*.db
*.sqlite
*.sqlite3

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Storage
storage/datasets/*
!storage/datasets/.gitkeep
storage/processed/*
!storage/processed/.gitkeep
storage/results/*
!storage/results/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/temp/*
!storage/temp/.gitkeep

# Node (if using any frontend tooling)
node_modules/
package-lock.json
yarn.lock

# OS
.DS_Store
Thumbs.db
.Windows

# Temporary files
*.tmp
*.bak
*.swp
.*.swp

# IDE
.vscode/*
!.vscode/extensions.json
